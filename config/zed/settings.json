// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "edit_predictions": {
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": true
  },
  "features": {
    "edit_prediction_provider": "copilot",
    "copilot": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "preview_tabs": {
    "enabled": false
  },
  "collaboration_panel": {
    "button": false
  },
  "outline_panel": {
    "button": false
  },
  "notification_panel": {
    // Whether to show the notification panel button in the status bar.
    "button": false
  },
  "debug": {
    "ignore_vscode_config": true
  },

  // ======================== ASSISTANT ========================
  "language_models": {
    "anthropic": {
      "version": "1"
    }
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-3.7-sonnet"
    },
    "default_profile": "write",
    "version": "2"
  },
  "enable_experimental_live_diffs": true,

  // ======================== IDE ========================
  "autosave": "on_focus_change",
  "tab_bar": {
    "show": true
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "all"
  },

  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "button": false
  },
  "gutter": {
    "line_numbers": true
  },
  // Whether to pop the completions menu while typing in an editor without
  // explicitly requesting it.
  "show_completions_on_input": true,

  // ======================== EDITOR ========================
  "cursor_blink": true,
  "inlay_hints": {
    "enabled": true
  },
  "preferred_line_length": 180,
  "soft_wrap": "preferred_line_length",
  "show_whitespaces": "all",
  "indent_guides": {
    "enabled": false,
    "coloring": "indent_aware"
  },
  "relative_line_numbers": true,
  "use_smartcase_search": true,

  // ======================== APPEARANCE ========================
  // "theme": "Colorizer",
  "theme": "XY-Zed",
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "ui_font_features": {
    "calt": true
  },
  "buffer_font_size": 20,
  "buffer_line_height": "comfortable",
  // "buffer_font_family": "Monaspace Neon",
  // "buffer_font_family": "Rec Mono Casual",
  "buffer_font_family": "Maple Mono",
  "buffer_font_fallbacks": ["Rec Mono Casual"],
  // "buffer_font_family": "Operator Mono Lig",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "dlig": true,

    // Maple Mono features
    "cv62": true, // Alternative ? with larger openings
    "cv65": true, // Alternative & in handwriting style
    // "zero": true, // Dot style 0
    "ss03": true, // Allow to use any case in all tags [TODO] [WARning]
    "ss04": false, // Broken multiple underscores ligatures (__, #__)
    "ss05": false, // Revert thin backslash in escape symbols (\\, \", \. ...)
    "ss06": false, // Break connected strokes between italic letters (al, il, ull ...)
    "ss07": true, // Relax the conditions for multiple greaters ligatures (>> or >>>)
    "ss08": true, // Double headed arrows and reverse arrows ligatures (>>=, -<<, ->>, >>- ...)
    "ss09": true, // Asciitilde equal as not equal to ligature (~=, !=)
    "ss10": true, // Approximately equal to and approximately not equal to ligatures (=~, !~)
    "ss11": true // Equal and extra punctuation ligatures (|=, /=, ?=, &=, ...)
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic"
      }
    }
  },
  "terminal": {
    "copy_on_select": true,
    "font_family": "Maple Mono",
    "font_fallbacks": ["Symbols Nerd Font Mono"],
    "font_size": 20,
    "font_features": {
      "calt": true,
      "liga": true,
      "dlig": true,

      // Maple Mono features
      "cv62": true, // Alternative ? with larger openings
      "cv65": true, // Alternative & in handwriting style
      // "zero": true, // Dot style 0
      "ss03": true, // Allow to use any case in all tags [TODO] [WARning]
      "ss04": false, // Broken multiple underscores ligatures (__, #__)
      "ss05": false, // Revert thin backslash in escape symbols (\\, \", \. ...)
      "ss06": false, // Break connected strokes between italic letters (al, il, ull ...)
      "ss07": true, // Relax the conditions for multiple greaters ligatures (>> or >>>)
      "ss08": true, // Double headed arrows and reverse arrows ligatures (>>=, -<<, ->>, >>- ...)
      "ss09": true, // Asciitilde equal as not equal to ligature (~=, !=)
      "ss10": true, // Approximately equal to and approximately not equal to ligatures (=~, !~)
      "ss11": true // Equal and extra punctuation ligatures (|=, /=, ?=, &=, ...)
    }
  },
  // ======================== LANGUAGE SERVER ========================
  "languages": {
    "YAML": {
      "formatter": "language_server"
    }
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          // "keyOrdering": true,
          "format": {
            "enable": false,
            "singleQuote": true
          }
        }
      }
    },
    // https://github.com/golang/tools/blob/master/gopls/doc/settings.md
    "gopls": {
      "initialization_options": {
        "formatting.gofumpt": false, // more strict formatting which I like
        "codelenses": {
          "gc_details": true,
          "test": true
        },
        "semanticTokens": true,
        "experimentalPostfixCompletions": true,
        "staticcheck": true,
        "analyses": {
          "nilness": true,
          "unusedparams": true,
          "unusedvariable": true,
          "unusedwrite": true,
          "useany": true
        },
        "hints": {
          "assignVariableTypes": false,
          "compositeLiteralFields": false,
          "compositeLiteralTypes": false,
          "constantValues": false,
          "functionTypeParameters": false,
          "parameterNames": true,
          "rangeVariableTypes": false
        }
      }
    }
  },
  "go.testTimeout": "600s",
  "go.testEnvVars": {
    "RUN_INTEGRATION_TESTS": "true",
    "TEST_AGAINST_REMOTE": "false"
  },

  // ======================== VIM ========================
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_multiline_find": true,
    "use_smartcase_find": true
  }
}
